<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- POS Configuration View - Add Novitus printer info -->
    <record id="view_pos_config_form_novitus" model="ir.ui.view">
        <field name="name">pos.config.form.novitus</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!-- Add Novitus info at the end of the sheet -->
            <xpath expr="//sheet" position="inside">
                <div class="alert alert-success mt-3" role="alert">
                    <strong>Novitus Fiscal Printer:</strong>
                    <span>
                        To add a Novitus fiscal printer, go to Point of Sale &gt; Configuration &gt; Preparation Printers
                        and select "Novitus Online Fiscal Printer" as the type.
                    </span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
